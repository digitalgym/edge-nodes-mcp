# ── Twilio (SMS nodes) ───────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── xAI / Grok (AI prompt nodes) ────────────────────────────────────────────
XAI_API_KEY=

# ── Google Places (address lookup node) ──────────────────────────────────────
GOOGLE_API_KEY=

# ── Slack (slack-post node) ──────────────────────────────────────────────────
SLACK_BOT_TOKEN=

# ── Discord (discord-send node) ──────────────────────────────────────────────
DISCORD_BOT_TOKEN=

# ── Supabase (supabase-query node) ───────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── OpenAI (openai-prompt node) ──────────────────────────────────────────────
OPENAI_API_KEY=

# ── MCP Auth (optional: protect execute endpoints) ───────────────────────────
MCP_SECRET=

# ── Base URL (set automatically by Vercel, override for local dev) ───────────
BASE_URL=http://localhost:3000
